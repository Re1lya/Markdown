# Defaults for installing the POC into a fresh kind cluster.
#
# kind creates this context automatically when the cluster name is platform-poc:
#   kind create cluster --config configs/kind-platform-poc.yaml
export KUBE_CONTEXT="${KUBE_CONTEXT:-kind-platform-poc}"

# User-facing demo addresses for the second server.
# Replace localhost with the server IP/domain if you access the demo remotely.
export SERVER_HOST="${SERVER_HOST:-localhost}"
export BACKSTAGE_BASE_URL="${BACKSTAGE_BASE_URL:-http://${SERVER_HOST}:7007}"
export DEMO_BASE_URL="${DEMO_BASE_URL:-http://${SERVER_HOST}:30080}"

# The custom Backstage image must be pullable by the target kind cluster.
# Build and push this image before installing Backstage on another server.
export BACKSTAGE_IMAGE_REGISTRY="${BACKSTAGE_IMAGE_REGISTRY:-ghcr.io}"
export BACKSTAGE_IMAGE_REPOSITORY="${BACKSTAGE_IMAGE_REPOSITORY:-re1lya/platform-poc-backstage}"
export BACKSTAGE_IMAGE_TAG="${BACKSTAGE_IMAGE_TAG:-0.1.5}"
